# 이 파일은 "예시"다. 실제 키를 여기 쓰지 말 것.
# 로컬 테스트할 때만 .env.local 파일을 따로 만들어 거기에 키를 넣는다. (.env.local은 git에 안 올라감)
# 실제 배포 키는 Vercel 대시보드 → Settings → Environment Variables 에 넣는다.

# Google AI Studio (https://aistudio.google.com)에서 발급
GEMINI_API_KEY=여기에_키

# (선택) 모델 바꾸고 싶을 때. 안 넣으면 기본값 사용.
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_GOOD=gemini-2.5-flash

# FastAPI backend
DATABASE_URL=postgresql+asyncpg://instarchat:instarchat@localhost:7555/instarchat
FRONTEND_ORIGINS=http://localhost:5173
AUTH_SECRET_KEY=긴_랜덤_문자열로_교체
AUTH_COOKIE_SECURE=false

# Google ID login
GOOGLE_CLIENT_ID=Google_OAuth_Client_ID
GOOGLE_CLIENT_SECRET=Google_OAuth_Client_Secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Apple ID login
APPLE_CLIENT_ID=Apple_Service_ID
APPLE_CLIENT_SECRET=Apple_Client_Secret_JWT
APPLE_REDIRECT_URI=http://localhost:8000/api/auth/apple/callback

# Legacy Supabase Auth + DB 저장. Phase 8에서 제거 예정.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
